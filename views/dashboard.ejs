<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Civitas Construction - Email Sender</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  </head>
  <body>
    <a href="/logout" class="logout-button-icon"
      ><i class="fas fa-sign-out-alt"></i> Logout</a
    >
    <div class="container dashboard-container">
      <div class="header">
        <h1>Email Dashboard</h1>
      </div>
      <form
        action="/send"
        method="POST"
        enctype="multipart/form-data"
        onsubmit="return confirmSend(event);">
        <div class="dashboard-grid">
          <div class="left-column">
            <div class="input-group">
              <label for="csvfile">Upload CSV File</label>
              <input
                type="file"
                id="csvfile"
                name="csvfile"
                accept=".csv"
                required />
            </div>
            <div class="input-group">
              <label for="attachment">Attach a file (optional)</label>
              <input
                type="file"
                id="attachment"
                name="attachment"
                accept="application/pdf,image/*,video/*" />
              <small
                >Supported: PDF, images, videos. Max file size depends on your
                SMTP provider.</small
              >
              <div
                id="attachment-info"
                style="margin-top: 6px; font-size: 0.9rem; color: #333"></div>
            </div>
            <div class="input-group">
              <label>Email Format</label>
              <div class="radio-group">
                <input
                  type="radio"
                  id="plain"
                  name="emailType"
                  value="plain"
                  checked />
                <label for="plain">Plain Text</label>
                <input type="radio" id="html" name="emailType" value="html" />
                <label for="html">HTML</label>
              </div>
            </div>
          </div>
          <div class="center-column">
            <div class="input-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" required />
            </div>
            <div class="input-group">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                rows="15"
                required></textarea>
            </div>
            <button type="submit">Send Emails</button>
          </div>
        </div>
      </form>
    </div>
    <script>
      // Attachment UI feedback
      (function () {
        const attachmentInput = document.getElementById("attachment");
        const info = document.getElementById("attachment-info");
        const submitButton = document.querySelector('button[type="submit"]');
        const MAX_BYTES = 10 * 1024 * 1024; // 10 MB

        if (attachmentInput) {
          attachmentInput.addEventListener("change", () => {
            const file = attachmentInput.files && attachmentInput.files[0];
            if (!file) {
              info.textContent = "";
              submitButton.disabled = false;
              return;
            }

            const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
            info.textContent = `${file.name} — ${sizeMB} MB`;

            if (file.size > MAX_BYTES) {
              info.style.color = "crimson";
              // Warning only: do not disable submit, user may still choose to send
              info.textContent +=
                " — File appears large (over 10 MB). Your SMTP provider may reject large attachments.";
            } else {
              info.style.color = "#333";
            }
          });
        }
      })();

      async function countCsvContacts(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const text = reader.result;
            const lines = text
              .split(/\r?\n/)
              .map((line) => line.trim())
              .filter((line) => line.length > 0);

            let contactCount = lines.length;
            if (contactCount === 0) {
              return resolve(0);
            }

            const header = lines[0].toLowerCase();
            if (
              /^(name|email|partner|schoolname)(\s*[;,\t])/i.test(lines[0]) ||
              header.includes("email") ||
              header.includes("name")
            ) {
              contactCount = Math.max(0, contactCount - 1);
            }

            resolve(contactCount);
          };
          reader.onerror = () => reject(reader.error);
          reader.readAsText(file);
        });
      }

      async function confirmSend(event) {
        event.preventDefault();
        const form = event.target;
        const csvInput = document.getElementById("csvfile");
        const attachmentInput = document.getElementById("attachment");
        const csvFile = csvInput.files && csvInput.files[0];
        const attachmentFile =
          attachmentInput.files && attachmentInput.files[0];

        if (!csvFile) {
          Swal.fire({
            title: "CSV required",
            text: "Please attach a CSV file before sending.",
            icon: "warning",
          });
          return false;
        }

        let contactCount = 0;
        try {
          contactCount = await countCsvContacts(csvFile);
        } catch (error) {
          Swal.fire({
            title: "CSV read error",
            text: "Could not read the CSV file. Please try again.",
            icon: "error",
          });
          return false;
        }

        const attachmentLabel = attachmentFile
          ? `<p style="margin:0; font-size:0.88rem; color:#444">Attachment:</p>
             <p style="margin:4px 0 0 0; font-size:1rem; color:#16a34a">${attachmentFile.name}</p>`
          : `<p style="margin:0; font-size:0.88rem; color:#444">Attachment:</p>
             <p style="margin:4px 0 0 0; font-size:1rem; color:#d93025">No Attachment</p>`;

        const html = `
          <div style="text-align:left; line-height:1.5">
            <p style="margin:0; font-size:0.88rem; color:#444">Total contacts:</p>
            <p style="margin:4px 0 12px 0; font-size:1.9rem; font-weight:700; color:#16a34a">${contactCount}</p>
            ${attachmentLabel}
            <p style="margin-top:16px; color:#555">Proceed?</p>
          </div>
        `;

        const result = await Swal.fire({
          title: "Ready to send?",
          html,
          icon: "question",
          showCancelButton: true,
          confirmButtonText: "Proceed",
          cancelButtonText: "Cancel",
          focusCancel: true,
          customClass: {
            popup: "swal2-border-radius",
          },
        });

        if (result.isConfirmed) {
          showProgress();
          form.submit();
        }

        return false;
      }

      function showProgress() {
        Swal.fire({
          title: "Sending Emails...",
          text: "Please wait.",
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          },
        });
      }

      const status = "<%- status %>";
      if (status === "success") {
        Swal.fire({
          title: "Success!",
          text: "Emails sent successfully.",
          icon: "success",
        });
      } else if (status === "error") {
        Swal.fire({
          title: "Error!",
          text: "An error occurred. Please check the console for details.",
          icon: "error",
        });
      }
    </script>
  </body>
</html>
